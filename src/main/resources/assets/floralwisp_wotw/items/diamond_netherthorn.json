{
  "model": {
    "type": "minecraft:condition",
    "property": "minecraft:has_component",
    "component": "floralwisp_wotw:warped_variant",
    "on_false": {
        "type": "minecraft:select",
        "cases": [
          {
            "model": {
              "type": "minecraft:model",
              "model": "floralwisp_wotw:item/diamond_crimsonthorn"
            },
            "when": [
              "gui",
              "ground",
              "fixed",
              "on_shelf"
            ]
          }
        ],
        "fallback": {
          "type": "minecraft:model",
          "model": "floralwisp_wotw:item/diamond_crimsonthorn_in_hand"
        },
        "property": "minecraft:display_context"
    },
    "on_true": {
        "type": "minecraft:select",
        "cases": [
          {
            "model": {
              "type": "minecraft:model",
              "model": "floralwisp_wotw:item/diamond_warpedthorn"
            },
            "when": [
              "gui",
              "ground",
              "fixed",
              "on_shelf"
            ]
          }
        ],
        "fallback": {
          "type": "minecraft:model",
          "model": "floralwisp_wotw:item/diamond_warpedthorn_in_hand"
        },
        "property": "minecraft:display_context"
    }    
  }
}